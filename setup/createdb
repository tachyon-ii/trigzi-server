#!/bin/sh
#
# create_db.sh
#
# Creates the MariaDB database, user, and products table for Trigzi.
#
# Usage:
#   ./create_db.sh <database_name> <password>
#

MYSQL=mysql

if [ ! $1 ] || [ ! $2 ]; then
    if [ ! $1 ]; then echo "Database name required"; fi
    if [ ! $2 ]; then echo "DB password required"; fi
    echo "Usage: ${0} <database_name> <password>"
    exit 1
fi

read -r -d '' SQL <<EOF
-- ── Database & User ───────────────────────────────────────────────────────────

DROP DATABASE IF EXISTS ${1};
DROP USER IF EXISTS '${1}'@'localhost';

CREATE DATABASE ${1}
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_unicode_ci;

CREATE USER '${1}'@'localhost' IDENTIFIED BY '${2}';
GRANT ALL ON ${1}.* TO '${1}'@'localhost';
FLUSH PRIVILEGES;

USE ${1};

-- ── Enrichments table ─────────────────────────────────────────────────────────
--
-- Tracks the exact LLM model + prompt version that produced each enrichment.
-- products.enrichment_id is a FK to this table.
-- Re-enrichment candidates (prompt OR model changed):
--   SELECT gtin FROM products
--   WHERE enrichment_id IN (
--     SELECT id FROM enrichments
--     WHERE prompt_ver != 'extract_v3'
--     OR llm_model NOT IN ('gemini-2.5-flash')
--   )
--

CREATE TABLE enrichments (
    id          INT             NOT NULL AUTO_INCREMENT,
    task        VARCHAR(50)     NOT NULL,           -- 'product', 'ocr_analysis'
    llm_model   VARCHAR(100)    NOT NULL,           -- 'gemini-2.5-flash'
    prompt_ver  VARCHAR(20)     NOT NULL,           -- 'extract_v2'
    prompt_hash CHAR(8)         NOT NULL,           -- first 8 chars SHA256 of prompt text
    prompt_text MEDIUMTEXT      NOT NULL,           -- full prompt for exact reproduction
    created_at  TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,

    PRIMARY KEY (id),
    UNIQUE KEY idx_prompt_model (prompt_hash, llm_model), -- dedup: same prompt+model = same row
    INDEX idx_task_prompt (task, prompt_ver)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;

-- ── Products table ────────────────────────────────────────────────────────────
--
-- gtin          Primary key — normalised to 13 digits per OFF spec
-- source        Origin: "off", "woolworths", "coles", "ocr"
-- name          Denormalised for fast name search
-- enrichment_id FK to enrichments — null = not yet enriched
-- data          Full unified product JSON blob (product_schema.json)
-- updated_at    Auto-updated on every write
--

CREATE TABLE products (
    gtin          VARCHAR(13)     NOT NULL,
    source        VARCHAR(20)     NOT NULL DEFAULT 'off',
    name          VARCHAR(150)    NOT NULL DEFAULT '',
    enrichment_id INT             NULL,
    data          JSON            NOT NULL,
    updated_at    TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP
                                  ON UPDATE CURRENT_TIMESTAMP,

    PRIMARY KEY (gtin),
    INDEX idx_name        (name),
    INDEX idx_source      (source),
    INDEX idx_enriched    (enrichment_id),
    INDEX idx_updated     (updated_at),
    CONSTRAINT fk_enrichment
        FOREIGN KEY (enrichment_id) REFERENCES enrichments(id)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;

EOF

echo "Running this SQL:"
echo ""
echo "$SQL"
echo ""
echo "Please input the root password for MySQL"
echo ""
printf '%s\n' "$SQL" | $MYSQL -u root -p

echo "Done!"
