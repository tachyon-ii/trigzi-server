#!/usr/bin/env python3
import asyncio
import argparse
import json
import os
import sys
import time
from pathlib import Path
import uuid

# 1. Bootstrap the Python path BEFORE importing local modules.
# This tells Python that the root 'trigzi' folder is a valid place to look for packages.
BASE_DIR = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(BASE_DIR))

# 2. Use absolute imports now that the path is aware of the root directory
from core.llm.router import LLMRouter 
from core.llm.skills import SkillsLibrary

# Instantiate your router
llm_router = LLMRouter()

# --- Configuration & Paths ---
PROVIDERS_FILE = BASE_DIR / "core" / "llm" / "llm_providers.json"
FIXTURES_DIR = BASE_DIR / "tests" / "fixtures"

def load_providers():
    if not PROVIDERS_FILE.exists():
        print(f"❌ Error: Providers config not found at {PROVIDERS_FILE}")
        sys.exit(1)
    with open(PROVIDERS_FILE, 'r') as f:
        providers = json.load(f)
    print(f"✅ LLMProviderConfig: loaded {len(providers)} providers from {PROVIDERS_FILE}")
    return providers

def get_task_payload_and_prompt(task, content):
    """
    Router for building the strict API payload based on the task name.
    """
    if task == "enrich_product":
        system_prompt = (
            "You are a strictly clinical dietary analysis engine. "
            "Analyze the provided product JSON for hidden allergens and dietary risks. "
            "Output your analysis strictly in flat JSON format."
        )
        user_prompt = f"[PRODUCT DATA]\n{content}\n\n[OUTPUT FORMAT]\nReturn strictly JSON."
        payload = {
            "prompt": f"{system_prompt}\n\n{user_prompt}" # Ensure it uses the 'prompt' key!
        }
        return payload, user_prompt

    elif task == "chat":
        data = json.loads(content)
        
        ctx_str = (
            f"Dietary Profile: {json.dumps(data.get('system_context', {}).get('dietary_profile', {}))}\n"
            f"Active Menu Context: {json.dumps(data.get('system_context', {}).get('current_menu', []))}"
        )
        
        hist_str = ""
        for msg in data.get("history", []):
            role = "User" if msg.get("role") == "user" else "Trigzi"
            hist_str += f"{role}: {msg.get('content', '')}\n"

        prompt = SkillsLibrary.chat_assistant_prompt(
            system_context=ctx_str,
            history=hist_str,
            message=data.get("message", "")
        )

        # THE CRITICAL FIX: Wrap it in the abstract "prompt" key 
        # so BaseProvider passes it to RequestFilter.build_text_payload
        payload = {
            "prompt": prompt 
        }
        return payload, prompt

    raise ValueError(f"Payload builder not implemented for task: '{task}'")

async def execute_llm_request(model_name, payload):
    """
    Executes a strict, 1:1 API call via the core router.
    Bypasses standard routing logic (failovers/races) to ensure clean benchmark data.
    """
    session_id = f"bench-{uuid.uuid4().hex[:8]}"
    
    try:
        # Hitting the internal method to guarantee a direct API strike
        result = await llm_router._execute_direct(
            payload=payload,
            profile="benchmark", # Adjust if your router expects a specific string here
            model_str=model_name,
            session_id=session_id,
            timeout=45.0
        )
        
        # Your router returns a Dict[str, Any]. 
        # Depending on how your router normalizes responses, extract the text here.
        # It's likely something like result.get('content') or result['choices'][0]['message']['content']
        
        # For now, let's pretty-print the raw dictionary so you can see exactly what comes back:
        return json.dumps(result, indent=2)
        
    except Exception as e:
        return f"❌ Router Exception: {str(e)}"

async def evaluate_model(model_name, task, content):
    """Builds the payload and executes the network request for a single model."""
    start_time = time.time()
    try:
        payload, prompt_text = get_task_payload_and_prompt(task, content)
        print(f"📡 Sending request to {model_name}...")
        
        response = await execute_llm_request(model_name, payload)
        
        elapsed = time.time() - start_time
        return {
            "model": model_name,
            "status": "success",
            "time": round(elapsed, 2),
            "response": response
        }
    except Exception as e:
        elapsed = time.time() - start_time
        return {
            "model": model_name,
            "status": "error",
            "time": round(elapsed, 2),
            "error": str(e)
        }

async def main():
    parser = argparse.ArgumentParser(description="Run LLM benchmarking tasks.")
    parser.add_argument("task", help="The specific benchmark task to run (e.g., enrich_product, chat)")
    parser.add_argument("-v", "--verbosity", type=int, default=1, help="Output verbosity level")
    args = parser.parse_args()

    providers = load_providers()

    # Dynamically read models from llm_providers.json routing config
    routing_config = providers.get("routing", {}).get(args.task, {})
    target_models = routing_config.get("models", [])
    
    # The 2026 Featherweight Division
    #target_models = [
    #    "gemini-2.5-flash-lite",
    #    "claude-haiku-4-5-20251001",
    #    "gpt-5.4-nano"
    #]

    print(f"🚀 Initializing Benchmark Pipeline for task: {args.task}")
    print(f"📡 Target Models: {', '.join(target_models)}")

    # 1. Dynamically select the fixture based on the task
    if args.task == "chat":
        fixture_name = "chat_eval.json"
    else:
        fixture_name = "truffle_sauce.json"

    fixture_path = FIXTURES_DIR / fixture_name
    
    # 2. THE HARD ABORT: Fail fast and loud if the contract is broken
    if not fixture_path.exists():
        print(f"❌ CRITICAL ERROR: Fixture file not found.")
        print(f"Expected path: {fixture_path}")
        print(f"Please ensure '{fixture_name}' exists in the tests/fixtures/ directory before running the '{args.task}' benchmark.")
        sys.exit(1)

    print(f"📁 Found fixture at {fixture_path.name}. Beginning evaluation...\n")

    with open(fixture_path, 'r', encoding='utf-8') as f:
        content = f.read()

    # 3. Fan out to all models concurrently
    tasks = [evaluate_model(model, args.task, content) for model in target_models]
    results = await asyncio.gather(*tasks)

    # 4. Output Results
    print("-" * 50)
    print("🏆 BENCHMARK RESULTS")
    print("-" * 50)
    for res in results:
        model = res['model']
        if res['status'] == 'success':
            print(f"🟢 {model} ({res['time']}s):\n{res['response']}\n")
        else:
            print(f"🔴 {model} ({res['time']}s) FAILED:\n{res['error']}\n")

if __name__ == "__main__":
    # Prevent "Event loop is closed" errors on Windows/certain environments
    if sys.platform == 'win32':
        asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
    asyncio.run(main())
